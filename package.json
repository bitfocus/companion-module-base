{
	"name": "@companion-module/api",
	"license": "MIT",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "run build:schema && run build:root",
		"build:clean": "(rm -rf ./packages/*/dist ./packages/*/generated ./packages/*/*.tsbuildinfo || true) && run build",
		"build:root": "tsc --build tsconfig.json",
		"build:schema": "cd packages/base && node ./tools/schema-compile.mjs",
		"dev": "run build:root --watch",
		"lint": "eslint .",
		"unit": "vitest run",
		"unit:watch": "vitest"
	},
	"engines": {
		"node": "^22.20"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@tsconfig/node22": "^22.0.5",
		"@types/node": "^22.19.17",
		"@types/semver": "^7.7.1",
		"esbuild": "^0.27.7",
		"eslint": "^9.39.4",
		"json-schema-to-typescript": "^15.0.4",
		"prettier": "^3.8.3",
		"typedoc": "^0.28.19",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.5",
		"vitest-mock-extended": "^3.1.1",
		"zx": "^8.8.5"
	},
	"packageManager": "yarn@4.14.1"
}
