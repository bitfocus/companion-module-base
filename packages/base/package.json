{
	"name": "@companion-module/base",
	"version": "2.2.0",
	"type": "module",
	"sideEffects": false,
	"license": "MIT",
	"repository": "https://github.com/bitfocus/companion-module-base",
	"exports": {
		".": {
			"import": "./dist/main.js",
			"require": "./dist/main.js"
		},
		"./manifest": {
			"import": "./dist/manifest.js",
			"require": "./dist/manifest.js"
		},
		"./host-api": {
			"import": "./dist/host-api/main.js",
			"require": "./dist/host-api/main.js"
		},
		"./package.json": {
			"import": "./package.json",
			"require": "./package.json"
		}
	},
	"scripts": {
		"docs:html": "run -BT typedoc --tsconfig tsconfig.json --readme README-typedoc.md --entryPoints src/docs.ts --excludePrivate --theme default --out docs"
	},
	"engines": {
		"node": "^22.20 || ^26.5"
	},
	"files": [
		"README.md",
		"CHANGELOG.md",
		"dist",
		"generated",
		"assets",
		"lib"
	],
	"dependencies": {
		"colord": "^2.9.3"
	},
	"devDependencies": {
		"ajv": "^8.20.0",
		"type-testing": "^0.2.0"
	}
}
